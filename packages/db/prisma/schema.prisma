// ══════════════════════════════════════════════
// GEOGRAPHIC CONFIGURATION — Support multi-pays
// ══════════════════════════════════════════════

enum CountryCode {
  CD // Rép. Démocratique du Congo (Kinshasa)
  GA // Gabon
  CG // Congo-Brazzaville
  AO // Angola
  CI // Côte d'Ivoire
  GN // Guinée Conakry
  SN // Sénégal
  MA // Maroc
}

enum Language {
  FR // Français
  EN // English
  LN // Lingala
  AR // العربية (Arabe)
}

model MarketCountry {
  id                 String      @id @default(cuid())
  code               CountryCode @unique
  nameEnglish        String
  nameFrench         String
  nameLocal          String?
  currency           String // EUR, USD, etc.
  currencyCode       String      @default("CDF") // ISO 4217
  currencySymbol     String      @default("FC")
  timezone           String
  dialCode           String // +243, +241, etc.
  nativeLanguage     Language    @default(FR)
  supportedLanguages Language[]  @default([FR, EN])
  taxRate            Float       @default(0.0) // TVA/VAT percentage
  region             String // Exemple: "Central Africa", "West Africa"
  isActive           Boolean     @default(true)
  population         Int?
  gdpPerCapita       Float?
  metadata           Json? // Config additionnelle pays
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  cities MarketCity[]

  @@index([code])
  @@index([isActive])
}

// ══════════════════════════════════════════════
// MARKET INTELLIGENCE — Données marché par ville/pays
// ══════════════════════════════════════════════

model MarketCity {
  id              String      @id @default(cuid())
  marketCountryId String
  city            String
  country         String
  countryCode     CountryCode @default(CD)
  currency        String      @default("CDF")
  timezone        String      @default("Africa/Kinshasa")
  isActive        Boolean     @default(true)
  metadata        Json? // Population, infos économiques, etc.
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  marketCountry MarketCountry @relation(fields: [marketCountryId], references: [id], onDelete: Cascade)
  stats         MarketStats[]

  @@unique([city, countryCode])
  @@index([marketCountryId])
  @@index([countryCode])
  @@index([isActive])
}

model MarketStats {
  id                  String   @id @default(cuid())
  marketCityId        String
  category            String // ex: "Nourriture", "Téléphone", "Vêtements"
  subcategory         String?
  avgPriceUsdCents    Int      @default(0)
  minPriceUsdCents    Int      @default(0)
  maxPriceUsdCents    Int      @default(0)
  medianPriceUsdCents Int      @default(0)
  sampleSize          Int      @default(0)
  demandScore         Int      @default(50) // 0-100 : indice de demande
  supplyScore         Int      @default(50) // 0-100 : indice d'offre
  trendDirection      String   @default("STABLE") // UP, DOWN, STABLE
  seasonalNotes       String?
  dataSource          String   @default("PLATFORM") // PLATFORM, MANUAL, API_EXTERNAL
  periodStart         DateTime
  periodEnd           DateTime
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  marketCity MarketCity @relation(fields: [marketCityId], references: [id], onDelete: Cascade)

  @@unique([marketCityId, category, periodStart])
  @@index([marketCityId, category])
  @@index([category, trendDirection])
  @@index([demandScore])
  @@index([periodStart, periodEnd])
}

// ══════════════════════════════════════════════
// SO-KIN TRENDS — Tendances, suggestions, IA sociale
// ══════════════════════════════════════════════

enum SoKinTrendType {
  HASHTAG
  TOPIC
  CATEGORY
  PRODUCT
  PROFILE
}

model SoKinTrend {
  id             String         @id @default(cuid())
  type           SoKinTrendType
  title          String
  description    String?
  score          Int            @default(0) // Score de popularité (0-1000)
  city           String?
  country        String?
  hashtags       String[]       @default([])
  relatedPostIds String[]       @default([])
  isActive       Boolean        @default(true)
  periodStart    DateTime
  periodEnd      DateTime
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([type, score])
  @@index([city])
  @@index([isActive, score])
  @@index([periodStart, periodEnd])
}

model SoKinSuggestion {
  id              String   @id @default(cuid())
  userId          String
  suggestedUserId String
  reason          String // MUTUAL_CONTACTS, SAME_CITY, SIMILAR_INTERESTS, FACEBOOK_FRIEND, PHONE_CONTACT
  score           Int      @default(0) // Score de pertinence (0-100)
  dismissed       Boolean  @default(false)
  connected       Boolean  @default(false)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User @relation("SuggestionTarget", fields: [userId], references: [id], onDelete: Cascade)
  suggestedUser User @relation("SuggestedUser", fields: [suggestedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, suggestedUserId])
  @@index([userId, dismissed, score])
  @@index([suggestedUserId])
}

// ══════════════════════════════════════════════
// USER CONTACTS — Import contacts (Facebook, Téléphone)
// ══════════════════════════════════════════════

enum ContactSource {
  PHONE
  FACEBOOK
  GOOGLE
  MANUAL
}

model UserContact {
  id            String        @id @default(cuid())
  userId        String
  source        ContactSource
  contactName   String?
  contactPhone  String?
  contactEmail  String?
  contactFbId   String?
  matchedUserId String? // Si ce contact correspond à un utilisateur Kin-Sell
  isFavorite    Boolean       @default(false)
  importedAt    DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user        User  @relation("ImportedContacts", fields: [userId], references: [id], onDelete: Cascade)
  matchedUser User? @relation("MatchedContacts", fields: [matchedUserId], references: [id], onDelete: SetNull)

  @@unique([userId, source, contactPhone])
  @@unique([userId, source, contactFbId])
  @@index([userId, source])
  @@index([matchedUserId])
  @@index([contactPhone])
  @@index([contactEmail])
}

// ══════════════════════════════════════════════
// SO-KIN CONNECTIONS — Relations entre utilisateurs
// ══════════════════════════════════════════════

enum ConnectionStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model SoKinConnection {
  id          String           @id @default(cuid())
  requesterId String
  receiverId  String
  status      ConnectionStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("ConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("ConnectionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@index([requesterId, status])
  @@index([receiverId, status])
}

// ══════════════════════════════════════════════
// VERIFICATION BADGE SYSTEM — Badges vérifiés utilisateurs & entreprises
// ══════════════════════════════════════════════

enum VerificationRequestSource {
  USER_REQUEST // Demande manuelle depuis le dashboard
  AI_AUTO // Recommandation/attribution automatique IA
  ADMIN_MANUAL // Action directe d'un admin
}

model VerificationRequest {
  id               String                    @id @default(cuid())
  userId           String? // Null si c'est une entreprise
  businessId       String? // Null si c'est un utilisateur
  source           VerificationRequestSource @default(USER_REQUEST)
  status           VerificationStatus        @default(PENDING)
  adminLocked      Boolean                   @default(false) // true = l'IA ne peut plus modifier
  aiScore          Float? // Score de crédibilité IA (0-100)
  aiRecommendation String? // Texte de recommandation IA
  aiEvaluatedAt    DateTime?
  adminNote        String? // Note de l'admin
  resolvedBy       String? // ID de l'admin qui a pris la décision
  resolvedAt       DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  // Métriques figées au moment de la demande / évaluation
  metricsSnapshot Json? // { completedOrders, avgRating, reviewCount, avgResponseTime, avgTransactionTime, disputeCount, reportCount, accountAge }

  user     User?                 @relation("VerificationRequests", fields: [userId], references: [id], onDelete: Cascade)
  business BusinessAccount?      @relation("BusinessVerificationRequests", fields: [businessId], references: [id], onDelete: Cascade)
  resolver User?                 @relation("VerificationResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)
  history  VerificationHistory[]

  @@index([userId, status])
  @@index([businessId, status])
  @@index([status, createdAt])
  @@index([resolvedBy])
}

model VerificationHistory {
  id          String                    @id @default(cuid())
  requestId   String
  action      String // REQUESTED, APPROVED, REJECTED, REVOKED, AI_ELIGIBLE, AI_PARTIAL, ADMIN_LOCKED, REACTIVATED
  fromStatus  VerificationStatus
  toStatus    VerificationStatus
  source      VerificationRequestSource
  performedBy String? // ID admin ou "SYSTEM" pour IA
  reason      String?
  metadata    Json?
  createdAt   DateTime                  @default(now())

  request VerificationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
}

// ══════════════════════════════════════════════
// SO-KIN REACTIONS — Réactions Facebook sur les posts
// ══════════════════════════════════════════════

enum SoKinReactionType {
  LIKE
  LOVE
  HAHA
  WOW
  SAD
  ANGRY
}

model SoKinReaction {
  id        String            @id @default(cuid())
  postId    String
  userId    String
  type      SoKinReactionType
  createdAt DateTime          @default(now())

  post SoKinPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

// ══════════════════════════════════════════════
// SO-KIN STORIES — Publications éphémères 24h
// ══════════════════════════════════════════════

enum SoKinStoryMediaType {
  IMAGE
  VIDEO
  TEXT
}

model SoKinStory {
  id          String              @id @default(cuid())
  authorId    String
  mediaUrl    String?
  mediaType   SoKinStoryMediaType @default(IMAGE)
  caption     String?
  bgColor     String? // Pour les stories texte
  scheduledAt DateTime?
  viewCount   Int                 @default(0)
  expiresAt   DateTime // Auto-expiration 24h après création
  createdAt   DateTime            @default(now())

  author  User             @relation("SoKinStories", fields: [authorId], references: [id], onDelete: Cascade)
  viewers SoKinStoryView[]

  @@index([authorId])
  @@index([expiresAt])
  @@index([authorId, expiresAt])
}

model SoKinStoryView {
  id       String   @id @default(cuid())
  storyId  String
  userId   String
  viewedAt DateTime @default(now())

  story SoKinStory @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@index([userId])
}

// ══════════════════════════════════════════════
// BUSINESS FOLLOW — Suivi de boutiques
// ══════════════════════════════════════════════

model BusinessFollow {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  createdAt  DateTime @default(now())

  user     User            @relation("BusinessFollows", fields: [userId], references: [id], onDelete: Cascade)
  business BusinessAccount @relation("BusinessFollowers", fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId])
  @@index([userId])
}

// ══════════════════════════════════════════════
// AI RECOMMENDATIONS — Suggestions intelligentes
// ══════════════════════════════════════════════

model AiRecommendation {
  id           String    @id @default(cuid())
  engineKey    String // ads, analytics, negotiation, order, orchestrator
  userId       String
  businessId   String?
  accountType  String    @default("USER") // USER | BUSINESS
  triggerType  String // LISTING_PUBLISHED, MULTI_LISTINGS, SALES_GROWTH, SHOP_CREATED, STAGNATION, TRIAL_SUGGEST, UPSELL
  title        String
  message      String    @db.Text
  actionType   String // BOOST_ARTICLE, BOOST_SHOP, UPGRADE_PLAN, ACTIVATE_TRIAL, VIEW_ANALYTICS, ENABLE_AUTO_SALES, PRICE_ADVICE
  actionTarget String? // URL or plan code or listing ID
  actionData   Json? // extra context (listingId, suggestedPlan, etc.)
  priority     Int       @default(5) // 1=low, 10=critical
  dismissed    Boolean   @default(false)
  clicked      Boolean   @default(false)
  accepted     Boolean   @default(false)
  displayedAt  DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  user     User             @relation("AiRecommendations", fields: [userId], references: [id], onDelete: Cascade)
  business BusinessAccount? @relation("AiRecommendationsBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  @@index([userId, dismissed, createdAt])
  @@index([businessId, dismissed, createdAt])
  @@index([engineKey, triggerType])
  @@index([userId, triggerType])
  @@index([expiresAt])
}

// ══════════════════════════════════════════════
// AI TRIALS — Périodes d'essai intelligentes
// ══════════════════════════════════════════════

model AiTrial {
  id           String    @id @default(cuid())
  userId       String
  businessId   String?
  accountType  String    @default("USER") // USER | BUSINESS
  planCode     String // plan proposé (BUSINESS, SCALE, PRO_VENDOR, etc.)
  sourceEngine String // quelle IA a proposé (analytics, ads, orchestrator)
  reason       String // why this trial was proposed
  status       String    @default("PROPOSED") // PROPOSED, ACTIVE, EXPIRED, DECLINED, CONVERTED
  startsAt     DateTime?
  endsAt       DateTime?
  activatedAt  DateTime?
  activatedBy  String? // userId who activated (or SYSTEM)
  convertedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user     User             @relation("AiTrials", fields: [userId], references: [id], onDelete: Cascade)
  business BusinessAccount? @relation("AiTrialsBusiness", fields: [businessId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([businessId, status])
  @@index([status, endsAt])
  @@index([sourceEngine])
}

// ═══════════════════════════════════════════════════════
// IA STUDIO ADS — Créations publicitaires générées par IA
// ═══════════════════════════════════════════════════════

model AiAdCreative {
  id              String   @id @default(cuid())
  title           String
  adType          String // BOOST_ARTICLE, BOOST_SHOP, FORFAIT, IA_PROMO, ESSAI, AUTO_VENTE, UPGRADE, CUSTOM
  audienceType    String // USER, BUSINESS, ALL
  sourceEngine    String   @default("studio-ads") // studio-ads, auto-gen
  generatedBy     String   @default("SYSTEM") // SYSTEM or adminUserId
  contentText     String // texte publicitaire principal
  subtitle        String? // sous-titre optionnel
  mediaType       String   @default("TEXT") // TEXT, IMAGE, GIF, VIDEO, BANNER, CARD
  mediaUrl        String? // URL du média généré
  ctaLabel        String   @default("Découvrir")
  ctaTarget       String   @default("/pricing") // lien cible du CTA
  tone            String   @default("premium") // premium, agressif, doux, vendeur, informatif
  tags            String[] // tags pour le ciblage (gaming, mode, electronique, etc.)
  status          String   @default("DRAFT") // DRAFT, READY, PUBLISHED, ARCHIVED
  // Ciblage optionnel
  targetPlanCodes String[] // forfaits ciblés (FREE, BOOST, etc.)
  targetCategory  String? // catégorie article ciblée
  // Variantes A/B
  variantGroup    String? // groupe de test A/B
  variantLabel    String? // A, B, C...
  // Relations
  userId          String?
  businessId      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User?            @relation("AiAdCreativeUser", fields: [userId], references: [id], onDelete: SetNull)
  business  BusinessAccount? @relation("AiAdCreativeBusiness", fields: [businessId], references: [id], onDelete: SetNull)
  campaigns AiAdCampaign[]   @relation("CampaignCreative")

  @@index([status])
  @@index([adType])
  @@index([audienceType])
  @@index([sourceEngine])
  @@index([userId])
  @@index([variantGroup])
}

// ═══════════════════════════════════════════════════════
// IA ADS — Campagnes de diffusion intelligente
// ═══════════════════════════════════════════════════════

model AiAdCampaign {
  id                 String    @id @default(cuid())
  creativeId         String
  campaignName       String
  objective          String // CONVERSION, UPSELL, AWARENESS, TRIAL, RETENTION
  audienceRole       String    @default("ALL") // USER, BUSINESS, ALL
  audienceConditions Json? // conditions de ciblage JSON { minListings, planCodes, categories, cities }
  active             Boolean   @default(false)
  startsAt           DateTime?
  endsAt             DateTime?
  frequencyCap       Int       @default(3) // max affichages par user par jour
  priority           Int       @default(0) // 0=normal, 10=urgent
  budgetType         String    @default("INTERNAL") // INTERNAL (gratuit Kin-Sell), PAID
  // Relations
  userId             String? // créateur de la campagne (admin)
  businessId         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  creative   AiAdCreative      @relation("CampaignCreative", fields: [creativeId], references: [id], onDelete: Cascade)
  user       User?             @relation("AiAdCampaignUser", fields: [userId], references: [id], onDelete: SetNull)
  business   BusinessAccount?  @relation("AiAdCampaignBusiness", fields: [businessId], references: [id], onDelete: SetNull)
  placements AiAdPlacement[]   @relation("CampaignPlacements")
  metrics    AiAdPerformance[] @relation("CampaignPerformance")

  @@index([active, startsAt, endsAt])
  @@index([objective])
  @@index([audienceRole])
  @@index([creativeId])
  @@index([priority])
}

// ═══════════════════════════════════════════════════════
// IA ADS — Placements (où afficher dans Kin-Sell)
// ═══════════════════════════════════════════════════════

model AiAdPlacement {
  id           String   @id @default(cuid())
  campaignId   String
  pageKey      String // home, explorer, sokin, dashboard_user, dashboard_business, article, shop, pricing, kinsell
  componentKey String // banner_top, banner_bottom, sidebar, inline_card, popup, drawer, contextual, smart_popup
  priority     Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  campaign AiAdCampaign @relation("CampaignPlacements", fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, pageKey, componentKey])
  @@index([pageKey, active])
  @@index([componentKey])
}

// ═══════════════════════════════════════════════════════
// IA ADS — Métriques de performance
// ═══════════════════════════════════════════════════════

model AiAdPerformance {
  id                     String   @id @default(cuid())
  campaignId             String
  date                   DateTime @default(now()) @db.Date
  impressions            Int      @default(0)
  clicks                 Int      @default(0)
  dismissals             Int      @default(0)
  conversions            Int      @default(0)
  subscriptionsGenerated Int      @default(0)
  trialsActivated        Int      @default(0)
  revenue                Int      @default(0) // en cents USD
  createdAt              DateTime @default(now())

  campaign AiAdCampaign @relation("CampaignPerformance", fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([date])
}

// ═══════════════════════════════════════════════════════
// PROMOTIONS — Groupement d'articles en promotion
// ═══════════════════════════════════════════════════════

enum PromotionStatus {
  DRAFT // Brouillon, pas encore publié
  ACTIVE // En cours
  PAUSED // Mise en pause manuellement
  EXPIRED // Expirée automatiquement
  CANCELLED // Annulée par le vendeur
}

enum PromotionDiffusion {
  SIMPLE // Publication normale
  BOOSTED // Avec boost payant (IA Ads)
}

model Promotion {
  id          String             @id @default(cuid())
  ownerUserId String
  businessId  String?
  title       String? // Nom optionnel de la promo ("Soldes avril", etc.)
  status      PromotionStatus    @default(ACTIVE)
  diffusion   PromotionDiffusion @default(SIMPLE)
  startsAt    DateTime           @default(now())
  expiresAt   DateTime? // Null = pas d'expiration auto
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  ownerUser User             @relation("UserPromotions", fields: [ownerUserId], references: [id], onDelete: Cascade)
  business  BusinessAccount? @relation("BusinessPromotions", fields: [businessId], references: [id], onDelete: SetNull)
  items     PromotionItem[]

  @@index([ownerUserId, status])
  @@index([businessId, status])
  @@index([status, expiresAt])
  @@index([createdAt])
}

model PromotionItem {
  id                    String   @id @default(cuid())
  promotionId           String
  listingId             String
  originalPriceUsdCents Int // Snapshot du prix au moment de la création
  promoPriceUsdCents    Int // Prix promo appliqué
  createdAt             DateTime @default(now())

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([promotionId, listingId])
  @@index([promotionId])
  @@index([listingId])
}

// ══════════════════════════════════════════════
// VITRINES — Documents utilisateur (diplômes, certificats, etc.)
// ══════════════════════════════════════════════

model Vitrine {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String?
  mediaUrl     String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation("UserVitrines", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, displayOrder])
}
