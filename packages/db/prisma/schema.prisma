enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model BlogPost {
  id              String         @id @default(cuid())
  authorId        String
  title           String
  slug            String         @unique
  content         String
  excerpt         String?
  coverImage      String?
  mediaUrl        String?
  mediaType       String?
  gifUrl          String?
