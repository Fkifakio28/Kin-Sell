// ══════════════════════════════════════════
// SO-KIN LIVE — module historique (non exposé dans la v2 mobile annonces)
// ══════════════════════════════════════════

enum SoKinLiveStatus {
  WAITING // Salle d'attente avant démarrage
  LIVE // En cours de diffusion
  ENDED // Terminé
  CANCELED // Annulé
}

enum SoKinLiveAspect {
  LANDSCAPE // 16:9
  PORTRAIT // 9:16
}

model SoKinLive {
  id                String          @id @default(cuid())
  hostId            String
  title             String
  description       String?
  thumbnailUrl      String?
  aspect            SoKinLiveAspect @default(PORTRAIT)
  status            SoKinLiveStatus @default(WAITING)
  viewerCount       Int             @default(0)
  peakViewers       Int             @default(0)
  likesCount        Int             @default(0)
  giftsCount        Int             @default(0)
  featuredListingId String?
  replayUrl         String?
  startedAt         DateTime?
  endedAt           DateTime?
  tags              String[]        @default([])
  city              String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  host         User                   @relation("SoKinLiveHost", fields: [hostId], references: [id], onDelete: Cascade)
  participants SoKinLiveParticipant[]
  chatMessages SoKinLiveChat[]

  @@index([hostId])
  @@index([status])
  @@index([createdAt])
  @@index([status, viewerCount])
}

model SoKinLiveParticipant {
  id       String    @id @default(cuid())
  liveId   String
  userId   String
  role     String    @default("VIEWER") // VIEWER, GUEST (invité sur le live), MODERATOR
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  live SoKinLive @relation(fields: [liveId], references: [id], onDelete: Cascade)
  user User      @relation("SoKinLiveParticipants", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([liveId, userId])
  @@index([liveId])
  @@index([userId])
  @@index([liveId, leftAt])
}

model SoKinLiveChat {
  id        String   @id @default(cuid())
  liveId    String
  userId    String
  text      String
  isGift    Boolean  @default(false)
  giftType  String?
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())

  live SoKinLive @relation(fields: [liveId], references: [id], onDelete: Cascade)
  user User      @relation("SoKinLiveChatMessages", fields: [userId], references: [id], onDelete: Cascade)

  @@index([liveId, createdAt])
  @@index([userId])
}

