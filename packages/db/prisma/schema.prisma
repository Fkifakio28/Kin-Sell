  @@index([fromCurrency])
}

model AiAgent {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  domain       String
  type         String     @default("general") // moderation, pricing, quality, negotiation, ordering, advertising, analytics, orchestration, security
  description  String?
  action       String?
