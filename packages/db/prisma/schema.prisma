  config       Json? // rich metadata: mission, zones, targets, uiEntryPoints, interventionType, requiredPlan, premiumOptions, dataUsed, outputs, subFunctions
  lastActiveAt DateTime?
  lastError    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([status])
  @@index([domain])
  @@index([type])
