// ══════════════════════════════════════════════
// SECURITY & TRUST SYSTEM
// ══════════════════════════════════════════════

enum TrustLevel {
  NEW // 0-39  — Très restreint
  STANDARD // 40-59 — Usage normal
  VERIFIED // 60-79 — Fiable
  PREMIUM // 80+   — Badge confiance
}

enum SanctionLevel {
  WARNING
  RESTRICTION
  FUNCTION_BLOCK
  SUSPENSION
  BAN
}

enum RestrictionType {
  MESSAGE_LIMIT
  LISTING_LIMIT
  NEGOTIATION_BLOCK
  VISIBILITY_REDUCED
  MANUAL_REVIEW
  SOKIN_RESTRICTED
  FULL_READONLY
}

model TrustScoreEvent {
  id        String     @id @default(cuid())
  userId    String
  delta     Int
  reason    String
  source    String
  newScore  Int
  newLevel  TrustLevel
  metadata  Json?
  createdAt DateTime   @default(now())

  user User @relation("TrustScoreUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  userId    String?
  eventType String
  ipAddress String?
  userAgent String?
  deviceId  String?
  metadata  Json?
  riskLevel Int      @default(0)
  createdAt DateTime @default(now())

  user User? @relation("SecurityUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([ipAddress, createdAt])
  @@index([riskLevel])
}

model UserRestriction {
  id              String          @id @default(cuid())
  userId          String
  restrictionType RestrictionType
  reason          String
  sanctionLevel   SanctionLevel   @default(RESTRICTION)
  isActive        Boolean         @default(true)
  appliedBy       String?
  expiresAt       DateTime?
  liftedAt        DateTime?
  createdAt       DateTime        @default(now())

  user User @relation("RestrictedUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([restrictionType, isActive])
  @@index([expiresAt])
}

model FraudSignal {
  id          String    @id @default(cuid())
  userId      String
  signalType  String
  severity    Int       @default(1)
  description String?
  metadata    Json?
  resolved    Boolean   @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  user User @relation("FraudSignalUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, resolved])
  @@index([signalType, createdAt])
  @@index([severity])
}

model RateLimitEntry {
  id          String   @id @default(cuid())
  key         String
  count       Int      @default(1)
  windowStart DateTime @default(now())
  expiresAt   DateTime

  @@unique([key])
  @@index([expiresAt])
}

// ══════════════════════════════════════════════
// MESSAGE GUARD AI — Contrôle conversationnel
// ══════════════════════════════════════════════

enum MessageGuardVerdict {
  ALLOWED
  WARNED
  BLOCKED
}

enum MessageGuardCategory {
  PHONE_NUMBER
  EMAIL
  EXTERNAL_LINK
  SOCIAL_HANDLE
  PLATFORM_EXIT_INTENT
  OFF_PLATFORM_TRADE
  OFF_PLATFORM_PAYMENT
  FRAGMENTED_INFO
  OBFUSCATED_CONTACT
  OTHER
}

model MessageGuardLog {
  id             String                 @id @default(cuid())
  userId         String
  conversationId String
  messageContent String?
  verdict        MessageGuardVerdict
  riskScore      Int                    @default(0)
  categories     MessageGuardCategory[]
  detections     Json?
  engineResults  Json?
  warningShown   String?
  createdAt      DateTime               @default(now())

  user User @relation("MessageGuardUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([verdict, createdAt])
  @@index([riskScore])
  @@index([conversationId, createdAt])
}

model MessageGuardFragment {
  id                String   @id @default(cuid())
  userId            String
  conversationId    String
  content           String
  normalizedContent String
  createdAt         DateTime @default(now())
  expiresAt         DateTime

  @@index([userId, conversationId, createdAt])
  @@index([expiresAt])
}

model MessageGuardConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

