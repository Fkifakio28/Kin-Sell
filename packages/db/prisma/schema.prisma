enum ReportStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

model Report {
  id             String       @id @default(cuid())
  reporterUserId String
  reportedUserId String
  reason         String
  message        String?
  status         ReportStatus @default(PENDING)
  resolvedBy     String?
  resolvedAt     DateTime?
