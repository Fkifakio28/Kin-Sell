  name          String
  description   String?
  priceUsdCents Int
  durationDays  Int
  features      String[]      @default([])
  status        AdOfferStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

