// ══════════════════════════════════════════════
// USER REVIEWS — Avis publics sur les profils
// ══════════════════════════════════════════════

model UserReview {
  id        String   @id @default(cuid())
  authorId  String
  targetId  String
  orderId   String? // lié à une commande réelle (avis vérifié)
  rating    Int // 1–5
  text      String?
  verified  Boolean  @default(false) // true si lié à une transaction réelle
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User   @relation("ReviewsGiven", fields: [authorId], references: [id], onDelete: Cascade)
  target User   @relation("ReviewsReceived", fields: [targetId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([authorId, targetId, orderId]) // un avis par personne par transaction
  @@index([targetId, createdAt])
  @@index([authorId])
  @@index([orderId])
}

