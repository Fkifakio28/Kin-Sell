DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kinsell?schema=public"
API_PORT=4000
WEB_PORT=5173
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d
SUPER_ADMIN_EMAIL=owner@kinsell.app
SUPER_ADMIN_PASSWORD=ChangeMe_Secure_123!
SUPER_ADMIN_DISPLAY_NAME=Kin-Sell Owner

# ── Cloudflare Turnstile ──
TURNSTILE_SECRET_KEY=REPLACE_WITH_TURNSTILE_SECRET_KEY
VITE_TURNSTILE_SITE_KEY=REPLACE_WITH_TURNSTILE_SITE_KEY
TURNSTILE_FAIL_OPEN=false
ALLOW_NATIVE_AUTH_CAPTCHA_FALLBACK=false

# ── Web Push (VAPID) ──
# Génération: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=VOTRE_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=VOTRE_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:contact@kin-sell.com

# ── Firebase Admin SDK (FCM push natif Android/iOS) ──
# Télécharger depuis Firebase Console → Paramètres → Comptes de service → Générer nouvelle clé privée
FIREBASE_PROJECT_ID=votre-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@votre-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── PayPal (compte marchand) ──
# Merchant ID disponible dans : Paramètres PayPal → Profil → Infos entreprise
VITE_PAYPAL_MERCHANT_ID=VOTRE_MERCHANT_ID_ICI
VITE_PAYPAL_MERCHANT_EMAIL=votre-email@paypal.com
# Lien direct de don (ex: https://www.paypal.com/donate/?hosted_button_id=XXXX)
VITE_PAYPAL_DONATION_URL=https://www.paypal.com/donate

# ── Distribution Android directe (hors Play Store) ──
# URL HTTPS stable vers l'APK signee. Utilisee uniquement sur mobile/tablette Android.
VITE_ANDROID_APK_URL=https://kin-sell.com/downloads/kin-sell.apk

# ── SMTP (envoi d'emails transactionnels & reset password) ──
# Si SMTP_USER ou SMTP_PASS est vide, l'API renvoie 503 sur "mot de passe oublié".
# SMTP_USER doit être une boîte SMTP valide chez votre fournisseur.
# SMTP_FROM peut afficher une adresse différente (alias) tant qu'elle est autorisée.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=REPLACE_WITH_SMTP_USER
SMTP_PASS=REPLACE_WITH_SMTP_PASSWORD
SMTP_FROM="Kin-Sell <no-reply@example.com>"

# ── SMS OTP (provider) ──
# SMS_PROVIDER : "disabled" (défaut) | "beem" (recommandé multi-pays) | "africastalking" (backup RDC bas coût)
# Si "disabled" en production, /account/otp/request renvoie 503.
# En NODE_ENV=development, previewCode reste retourné dans la réponse pour les tests.
SMS_PROVIDER=disabled

# ── Beem Africa (provider principal multi-pays Kin-Sell) ──
# Couvre CD/CG/CI/SN/GN/AO/MA/GA. Sender ID à enregistrer auprès de Beem.
# Compte : https://login.beem.africa → API Settings.
BEEM_API_KEY=REPLACE_WITH_BEEM_API_KEY
BEEM_SECRET_KEY=REPLACE_WITH_BEEM_SECRET_KEY
BEEM_SENDER_ID=Kin-sell

# ── Africa's Talking (backup, RDC bas coût) ──
# AT_SANDBOX=true → sandbox (test gratuit), false → production (numéros réels facturés).
# Compte : https://account.africastalking.com → Settings → API Key.
AT_USERNAME=sandbox
AT_API_KEY=REPLACE_WITH_AT_API_KEY
AT_SENDER_ID=
AT_SANDBOX=true

# ── Frontend feature flags (Vite) ──
# Active l'onglet "Téléphone (OTP)" sur /register et /login.
# Garder à "false" en prod tant que Beem (Sender Name "Kin-sell") n'est pas approuvé
# pour la couverture multi-pays. Mettre à "true" en dev local pour tester via AT sandbox.
# Variable absente = false (prod-safe).
VITE_ENABLE_PHONE_AUTH=false
