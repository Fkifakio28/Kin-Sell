{
  "name": "kin-sell",
  "private": true,
  "version": "3.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "local:start": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local.ps1",
    "dev": "npm run dev -w apps/api & npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -ws",
    "db:generate": "npm run generate -w packages/db",
    "db:migrate": "npm run migrate -w packages/db",
    "db:seed": "npm run seed -w packages/db"
  },
  "devDependencies": {
    "exceljs": "^4.4.0",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "hls.js": "^1.6.15"
  },
  "description": "Plateforme de marchandage, commande et echange reconstruite sur une base neuve.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fkifakio28/Kin-Sell.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Fkifakio28/Kin-Sell/issues"
  },
  "homepage": "https://github.com/Fkifakio28/Kin-Sell#readme"
}
